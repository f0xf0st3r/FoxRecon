# FoxRecon Environment Configuration
# Copy to .env and modify for your environment

# Application
APP_ENV=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
POSTGRES_USER=foxrecon
POSTGRES_PASSWORD=foxrecon_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=foxrecon
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Scan Engine
SCAN_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SCANS=10
SCAN_RATE_LIMIT_PER_MINUTE=50

# Tool paths (defaults assume installed in PATH)
SUBFINDER_PATH=subfinder
HTTPX_PATH=httpx
NAABU_PATH=naabu
NUCLEI_PATH=nuclei

# Nuclei configuration
NUCLEI_TEMPLATES_PATH=
NUCLEI_SEVERITY_FILTER=low,medium,high,critical
NUCLEI_RATE_LIMIT=50
NUCLEI_CONCURRENCY=25

# Storage
DATA_DIR=/tmp/foxrecon_data
